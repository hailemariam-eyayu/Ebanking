NODE_TLS_REJECT_UNAUTHORIZED=0

# Internet Banking database
IB_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/internet_banking?sslmode=disable"

PORT=5003
NODE_ENV=development

JWT_SECRET=change_me_to_a_strong_random_secret

# CBS SOAP endpoints
CBS_SOAP_URL=http://your-cbs-host/FCUBSCustomerService
CBS_ACC_SOAP_URL=http://your-cbs-host/FCUBSAccService
CBS_SOURCE=ADC
CBS_USER=ADCUSER
CBS_BRANCH=001

# A2A transfer service (BackendIB a2a.js / CBS RT service)
A2A_API_URL=http://10.1.12.35:4001

# CBS Oracle DB — direct balance queries (same SSH tunnel as BackendBO)
CBS_DB_URL=localhost:1522/FLEXCUBE
CBS_DB_Username=your_oracle_user
CBS_DB_Password=your_oracle_password
SSH_HOST=your_ssh_host
SSH_PORT=22
SSH_USER=your_ssh_user
SSH_PASSWORD=your_ssh_password
REMOTE_DB_HOST=10.1.22.x
REMOTE_DB_PORT=1521
