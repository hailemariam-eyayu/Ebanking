// Prisma Schema — BackendBO
// Two generators: one for BO models, one for IB models (cross-DB access).

generator boClient {
  provider = "prisma-client-js"
  output   = "../src/generated/bo-client"
}

generator ibClient {
  provider = "prisma-client-js"
  output   = "../src/generated/ib-client"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// BACK-OFFICE MODELS
// ─────────────────────────────────────────────────────────────────────────────

model BOUser {
  id            String   @id @default(uuid())
  username      String   @unique
  email         String   @unique
  passwordHash  String
  fullName      String
  role          BORole   @relation(fields: [roleId], references: [id])
  roleId        String
  branch        String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("bo_users")
}

model BORole {
  id          String        @id @default(uuid())
  name        String        @unique
  description String?
  menus       BOMenuRight[]
  users       BOUser[]
  createdAt   DateTime      @default(now())

  @@map("bo_roles")
}

model BOMenu {
  id      String        @id @default(uuid())
  key     String        @unique
  label   String
  icon    String?
  parent  String?
  order   Int           @default(0)
  rights  BOMenuRight[]

  @@map("bo_menus")
}

model BOMenuRight {
  id      String  @id @default(uuid())
  role    BORole  @relation(fields: [roleId], references: [id])
  roleId  String
  menu    BOMenu  @relation(fields: [menuId], references: [id])
  menuId  String
  canView Boolean @default(true)
  canEdit Boolean @default(false)

  @@unique([roleId, menuId])
  @@map("bo_menu_rights")
}

model AuditLog {
  id        String   @id @default(uuid())
  actor     String
  actorType String
  action    String
  entity    String
  entityId  String?
  details   Json?
  ip        String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// INTERNET BANKING MODELS (read/write cross-DB via prismaIB)
// ─────────────────────────────────────────────────────────────────────────────

model IBCustomer {
  id              String         @id @default(uuid())
  custNo          String         @unique
  fullName        String
  email           String?
  phone           String?
  branch          String
  accountType     AccountType    @default(INDIVIDUAL)
  activationLevel Int            @default(1)
  approvalLimit   Decimal?
  status          CustomerStatus @default(PENDING)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  ibUsers      IBUser[]
  transactions IBTransaction[]
  accounts     IBAccount[]

  @@map("ib_customers")
}

// ── Attached CBS accounts ──────────────────────────────────────────────────────
model IBAccount {
  id            String     @id @default(uuid())
  customerId    String
  customer      IBCustomer @relation(fields: [customerId], references: [id])
  accountNumber String
  accountClass  String?
  currency      String     @default("ETB")
  fullName      String?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())

  @@unique([customerId, accountNumber])
  @@map("ib_accounts")
}

enum AccountType {
  INDIVIDUAL
  CORPORATE
  GOVERNMENT
}

enum CustomerStatus {
  PENDING
  ACTIVE
  BLOCKED
  SUSPENDED
}

model IBUser {
  id           String            @id @default(uuid())
  customerId   String
  customer     IBCustomer        @relation(fields: [customerId], references: [id])
  username     String            @unique
  email        String            @unique
  passwordHash String
  fullName     String
  userRole     IBUserRole        @default(OWNER)
  isActive     Boolean           @default(true)
  viewOnly     Boolean           @default(false)
  menuRights   IBUserMenuRight[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  initiatedTxns IBTransaction[] @relation("Maker")
  checkedTxns   IBTransaction[] @relation("Checker")
  approvedTxns  IBTransaction[] @relation("Approver")

  @@map("ib_users")
}

enum IBUserRole {
  OWNER
  MAKER
  CHECKER
  APPROVER
  VIEWER
}

model IBUserMenuRight {
  id      String  @id @default(uuid())
  user    IBUser  @relation(fields: [userId], references: [id])
  userId  String
  menuKey String
  canView Boolean @default(true)
  canAct  Boolean @default(false)

  @@unique([userId, menuKey])
  @@map("ib_user_menu_rights")
}

model IBTransaction {
  id            String     @id @default(uuid())
  customerId    String
  customer      IBCustomer @relation(fields: [customerId], references: [id])
  type          TxnType
  fromAccount   String
  toAccount     String?
  amount        Decimal
  currency      String     @default("ETB")
  description   String?
  status        TxnStatus  @default(PENDING)
  workflowLevel Int

  makerId    String?
  maker      IBUser? @relation("Maker",    fields: [makerId],    references: [id])
  checkerId  String?
  checker    IBUser? @relation("Checker",  fields: [checkerId],  references: [id])
  approverId String?
  approver   IBUser? @relation("Approver", fields: [approverId], references: [id])

  makerAt        DateTime?
  checkerAt      DateTime?
  approverAt     DateTime?
  rejectedAt     DateTime?
  rejectedBy     String?
  rejectedReason String?
  cbsReference   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ib_transactions")
}

enum TxnType {
  INTERNAL_TRANSFER
  EXTERNAL_TRANSFER
  BILL_PAYMENT
  OWN_ACCOUNT_TRANSFER
}

enum TxnStatus {
  PENDING
  PENDING_CHECKER
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PROCESSED
  FAILED
}
