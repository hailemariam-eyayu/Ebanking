NODE_TLS_REJECT_UNAUTHORIZED=0

# Back-office database
BO_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/backoffice?sslmode=disable"

# IB database — needed only for cross-DB ib management routes
IB_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/internet_banking?sslmode=disable"

PORT=5002
NODE_ENV=development

JWT_SECRET=change_me_to_a_strong_random_secret

# CBS SOAP endpoints
CBS_SOAP_URL=http://your-cbs-host/FCUBSCustomerService
CBS_ACC_SOAP_URL=http://your-cbs-host/FCUBSAccService
CBS_SOURCE=ADC
CBS_USER=ADCUSER
CBS_BRANCH=001
